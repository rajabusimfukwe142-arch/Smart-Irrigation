// pages/api/users/[id].js
import fs from 'fs';
import path from 'path';

// Njia ya faili la watumiaji
const usersFilePath = path.join(process.cwd(), 'data', 'users.json');

// Helper: Soma watumiaji
const getUsers = () => {
  try {
    const data = fs.readFileSync(usersFilePath, 'utf8');
    return JSON.parse(data);
  } catch (error) {
    // Kama faili haipo, rudisha array tupu
    return [];
  }
};

// Helper: Hifadhi watumiaji
const saveUsers = (users) => {
  fs.writeFileSync(usersFilePath, JSON.stringify(users, null, 2), 'utf8');
};

export default function handler(req, res) {
  const { id } = req.query;
  const userId = parseInt(id);

  // GET - Pata mtumiaji
  if (req.method === 'GET') {
    const users = getUsers();
    const user = users.find(u => u.id === userId);
    if (!user) {
      return res.status(404).json({ success: false, error: 'Mtumiaji hapatikani' });
    }
    const { password, ...userWithoutPassword } = user;
    return res.status(200).json({ success: true, user: userWithoutPassword });
  }

  // PUT - Sasisha mtumiaji
  if (req.method === 'PUT') {
    const users = getUsers();
    const userIndex = users.findIndex(u => u.id === userId);
    
    if (userIndex === -1) {
      return res.status(404).json({ success: false, error: 'Mtumiaji hapatikani' });
    }

    const { name, phone, role, email, password } = req.body;
    
    // Sasisha data
    if (name) users[userIndex].name = name;
    if (phone) users[userIndex].phone = phone;
    if (role) users[userIndex].role = role;
    if (email) users[userIndex].email = email;
    if (password) users[userIndex].password = password;

    // Hifadhi kwenye faili
    saveUsers(users);

    const { password: _, ...userWithoutPassword } = users[userIndex];
    return res.status(200).json({ 
      success: true, 
      user: userWithoutPassword,
      message: 'Taarifa zimehifadhiwa kikamilifu!'
    });
  }

  return res.status(405).json({ success: false, error: 'Method not allowed' });
}
